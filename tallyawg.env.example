# Flags passed to `tallyawg serve` (word-split by systemd).
# Copied to /etc/tallyawg/tallyawg.env by install.sh.
#
#   -i <iface>        interface to account (default: auto-detect)
#   -config <file>    server .conf to read friendly "# name" peer comments from
#   -listen <addr>    web page address (default: 127.0.0.1:8082)
#   -interval <dur>   collection interval (default: 5m)
#   -names <file>     optional "<pubkey-or-address> <name>" mapping
#
TALLYAWG_FLAGS=-i awg0 -config /etc/amnezia/amneziawg/awg0.conf -listen 127.0.0.1:8082
